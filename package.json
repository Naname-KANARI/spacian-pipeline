{
  "name": "spacian-pipeline",
  "version": "1.0.0",
  "description": "SPACiAN news pipeline — collect, score, generate, publish",
  "type": "module",
  "scripts": {
    "collect": "tsx --env-file=.env src/collect.ts",
    "score": "tsx --env-file=.env src/score.ts",
    "generate": "tsx --env-file=.env src/generate.ts",
    "publish": "tsx --env-file=.env src/publish.ts",
    "pipeline": "npm run collect && npm run score && npm run generate && npm run publish",
    "cli": "tsx --env-file=.env src/cli.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "cheerio": "^1.2.0",
    "nodemailer": "^8.0.10",
    "rss-parser": "^3.13.0"
  },
  "devDependencies": {
    "@types/cheerio": "^0.22.35",
    "@types/node": "^25.9.2",
    "@types/nodemailer": "^8.0.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
